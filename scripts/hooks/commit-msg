#!/usr/bin/env bash
# Strips Cursor/AI attribution from commit messages before they are recorded.
# Install: ln -sf ../../scripts/hooks/commit-msg .git/hooks/commit-msg

set -euo pipefail

COMMIT_MSG_FILE="$1"
TMP_FILE="${COMMIT_MSG_FILE}.tmp"

# Remove Co-authored-by lines referencing Cursor or AI tools
sed -E \
  -e '/^[Cc]o-[Aa]uthored-by:.*[Cc]ursor/d' \
  -e '/^[Cc]o-[Aa]uthored-by:.*cursoragent/d' \
  -e '/^[Gg]enerated by [Aa][Ii]/d' \
  -e '/^[Tt]his (commit|change) was generated by/d' \
  "$COMMIT_MSG_FILE" > "$TMP_FILE"

mv "$TMP_FILE" "$COMMIT_MSG_FILE"
exit 0
