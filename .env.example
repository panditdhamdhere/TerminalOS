# TerminalOS environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# trace | debug | info | warn | error
RUST_LOG=terminalos=info

# -----------------------------------------------------------------------------
# AI providers (enable the matching provider in ~/.config/terminalos/config.toml)
# -----------------------------------------------------------------------------

# Groq (OpenAI-compatible API)
GROQ_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
